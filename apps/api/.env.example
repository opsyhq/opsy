DATABASE_URL=postgres://postgres:password@localhost:5432/opsy
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-plus-bytes-of-random
# AES-256-GCM key for encrypting integration credentials at rest.
# Base64 for exactly 32 bytes. Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=replace-me-with-base64-of-32-random-bytes
BETTER_AUTH_URL=http://localhost:4000
# Origin where the web app is served — used as the redirect target for
# loginPage, consentPage, device verificationUri, magic link, etc.
WEB_URL=http://localhost:3000
# Optional Google OAuth provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" in dev/test to bypass authentication entirely. When true,
# AUTH_SKIP_USER_ID and AUTH_SKIP_ORG_ID are REQUIRED (boot fails closed
# otherwise — no baked-in identity). Seed the backing user/org/member rows
# once with `bun run db:seed:auth-skip`. Never enable in production.
AUTH_SKIP=false
# Stub actor UUIDs used only when AUTH_SKIP=true. Generate with `uuidgen`.
AUTH_SKIP_USER_ID=
AUTH_SKIP_ORG_ID=
# Comma-separated app-level super admin emails allowed to use internal audit UI
OPSY_SUPER_ADMIN_EMAILS=
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
MAX_REQUEST_BODY_SIZE=1048576
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
# Defaults to DATABASE_URL when unset.
WORKFLOW_POSTGRES_URL=
WORKFLOW_POSTGRES_WORKER_CONCURRENCY=10
WORKFLOW_POSTGRES_MAX_POOL_SIZE=10
# Comma-separated Terraform provider catalog. Use | for multiple allowed
# versions of one provider, e.g. aws=hashicorp/aws@6.44.0|6.45.0
OPSY_TERRAFORM_PROVIDERS=aws=hashicorp/aws@6.44.0
# AWS region for SES (email sending). The SDK picks credentials up from
# the default chain — in deployed envs, the task role provides them; in
# local dev, leave the chain unset to fall back to logging links to stdout.
AWS_REGION=us-east-1
# Optional S3 bucket for runtime provider resource icons. Public URLs are
# derived from this bucket plus the icon asset region; provider roots are
# isolated under icons/<provider>/.
OPSY_ASSETS_S3_BUCKET=
# Optional model-backed catalog enrichment. Relationship rules use Azure OpenAI;
# display/icon/field metadata still use OpenAI directly.
OPENAI_API_KEY=
AZURE_OPENAI_RESOURCE_NAME=
AZURE_OPENAI_API_KEY=
# From address for transactional auth emails. When unset, email flows log
# the URL to stdout instead of sending through SES.
SES_FROM_ADDRESS=
