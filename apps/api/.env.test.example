DATABASE_URL=postgres://postgres:password@localhost:5432/opsy_test
PORT=4001
NODE_ENV=test
LOG_LEVEL=warn
BETTER_AUTH_SECRET=test-secret-not-real-at-least-32-bytes
CREDENTIALS_ENCRYPTION_KEY=BwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwcHBwc=
BETTER_AUTH_URL=http://localhost:4001
WEB_URL=http://localhost:3001
# When AUTH_SKIP=true, AUTH_SKIP_USER_ID and AUTH_SKIP_ORG_ID are required
# (boot fails closed otherwise). Seed backing rows with `bun run db:seed:auth-skip`.
AUTH_SKIP=false
AUTH_SKIP_USER_ID=
AUTH_SKIP_ORG_ID=
OPSY_SUPER_ADMIN_EMAILS=
CORS_ORIGIN=http://localhost:3001
# Bridge + provider dir are required whenever a test initializes providers.
# Run `make build` and `make setup` from the repo root first.
OPSY_BRIDGE_BIN=../../bin/opsy-bridge
OPSY_PROVIDER_DIR=../../tf-providers
# Comma-separated Terraform provider catalog. Use | for multiple allowed
# versions of one provider, e.g. aws=hashicorp/aws@6.44.0|6.45.0
OPSY_TERRAFORM_PROVIDERS=aws=hashicorp/aws@6.44.0
# Leave SES unset so emails log to stdout instead of trying to call AWS.
