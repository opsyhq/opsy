{
  "name": "@opsy/cli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "opsy": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"import('node:fs/promises').then(fs => fs.rm('dist', { recursive: true, force: true }).then(() => {}))\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test ./src"
  },
  "dependencies": {
    "@opsy/contracts": "workspace:*",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.0"
  }
}
