{
	"name": "@opsyhq/opsy",
	"version": "0.2.15",
	"private": false,
	"type": "module",
	"bin": {
		"opsy": "./dist/bin.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"dev": "bun run src/bin.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"build": "rm -rf dist && bun build src/bin.ts --target=node --format=esm --outfile=dist/bin.js && chmod +x dist/bin.js"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"@opsy/api": "workspace:*",
		"@opsy/contracts": "workspace:*",
		"better-auth": "^1.6.9",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"hono": "^4.12.12",
		"open": "^11.0.0"
	},
	"devDependencies": {
		"@opsy/provider": "workspace:*",
		"@types/bun": "^1.3.11",
		"typescript": "^6.0.2"
	}
}
