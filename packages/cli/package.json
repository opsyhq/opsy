{
  "name": "@opsyhq/opsy",
  "version": "0.1.4",
  "description": "Opsy CLI for agent-driven infrastructure management.",
  "type": "module",
  "homepage": "https://opsy.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opsyhq/opsy.git"
  },
  "bugs": {
    "url": "https://github.com/opsyhq/opsy/issues"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "opsy": "./dist/bin.js"
  },
  "scripts": {
    "build": "bun build src/bin.ts --target=node --format=esm --outdir=dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test src/commands",
    "pack:check": "npm pack --dry-run",
    "dev": "bun run src/bin.ts"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.19",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
