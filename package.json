{
	"name": "opsy-monorepo",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dead": "knip --use-tsconfig-files --include-entry-exports",
		"typecheck": "bun run --filter '*' typecheck",
		"test": "bun run --filter './packages/*' test",
		"lint": "biome check .",
		"format": "biome format --write .",
		"dev:api": "bun run --filter @opsy/api dev",
		"dev:web": "bun run --filter @opsy/web dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "^1.3.11",
		"knip": "^6.11.0",
		"typescript": "^6.0.2"
	},
	"patchedDependencies": {
		"env-runner@0.1.7": "patches/env-runner@0.1.7.patch"
	}
}
