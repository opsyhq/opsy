# Test environment for Opsy provider e2e tests.
# Copy this file: cp .env.test.example .env.test
# Load before running: source .env.test
# Or use direnv: ln -s .env.test .envrc
#
# Then run: make testacc

# ── AWS credentials ──────────────────────────────────────────────────────────
# Choose ONE of the three options below.

# Option A: Static credentials (CI/CD, IAM user with AdministratorAccess)
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=
export AWS_SESSION_TOKEN=      # only needed for STS/SSO temporary credentials

# Option B: Named profile from ~/.aws/credentials (local dev, aws-vault, etc.)
# export AWS_PROFILE=your-profile

# Option C: Leave all blank to use the SDK default chain
#   (instance role, ECS task role, ~/.aws/credentials default profile, etc.)

export AWS_REGION=us-east-1

# ── Opsy test config ──────────────────────────────────────────────────────────
export OPSY_LIVE=1
export OPSY_BRIDGE_BIN=$(pwd)/bin/opsy-bridge
export OPSY_PROVIDER_DIR=$(pwd)/tf-providers
# Comma-separated Terraform provider catalog. Use | for multiple allowed
# versions of one provider, e.g. aws=hashicorp/aws@6.44.0|6.45.0
export OPSY_TERRAFORM_PROVIDERS=aws=hashicorp/aws@6.44.0
